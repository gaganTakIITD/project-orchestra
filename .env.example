# Project Orchestra — environment template
# Copy to .env (backend/docker-compose) and .env.local (Next.js frontend)

# --- Backend (docker-compose + local uvicorn) ---
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://orchestra:orchestra@localhost:5432/orchestra
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=orchestra-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
SECRET_KEY=change-me-in-production
AUTO_SEED=true
# Dev: create tables from models on boot. In prod set false and run `alembic upgrade head`.
AUTO_CREATE_ALL=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Connection pool (production tuning)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Frontend binding (copy these to .env.local)
# Product path (local): real API against Docker — this is how the app "works"
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Mocks: omit NEXT_PUBLIC_USE_MOCKS or set true only for offline / CI / v0 without Docker

# --- Gemini AI gateway ---
# Leave GEMINI_API_KEY unset to run the deterministic fixture fallback.
# Set it to make the scope chat genuinely extract with Gemini (no other change needed).
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
