# Project Orchestra — environment template
# Copy to .env (backend/docker-compose) and .env.local (Next.js frontend)

# --- Backend (docker-compose + local uvicorn) ---
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://orchestra:orchestra@localhost:5432/orchestra
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=orchestra-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
SECRET_KEY=change-me-in-production
AUTO_SEED=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend binding (copy these to .env.local) ---
# Gate #1: catalog + taxonomy on real API
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Gemini (Phase B4 — not required for B1)
# GEMINI_API_KEY=
